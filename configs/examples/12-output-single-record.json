{
  "connector": {
    "name": "output-single-record-example",
    "version": "1.0.0",
    "description": "Example with single record mode (requestMode: single)",
    "input": {
      "type": "httpPolling",
      "endpoint": "https://api.example.com/users",
      "schedule": "*/5 * * * *",
      "timeoutMs": 30000
    },
    "filters": [],
    "output": {
      "type": "httpRequest",
      "endpoint": "https://api.destination.com/users/{userId}",
      "method": "PATCH",
      "requestMode": "single",
      "queryParams": {
        "updateSource": "cannectors"
      },
      "retry": {
        "maxAttempts": 2,
        "delayMs": 500
      },
      "onError": "skip",
      "authentication": {
        "type": "api-key",
        "credentials": {
          "key": "${API_KEY}",
          "location": "header",
          "headerName": "X-API-Key"
        }
      },
      "keys": [
        {
          "field": "id",
          "paramType": "path",
          "paramName": "userId"
        }
      ]
    }
  }
}